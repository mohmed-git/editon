{
  "name": "cinemana",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/build-episode-shards.mjs && node scripts/build-search-index.mjs",
    "build": "ASTRO_TELEMETRY_DISABLED=1 node scripts/build-episode-shards.mjs && node scripts/build-search-index.mjs && astro build && node scripts/fix-routes-json.mjs",
    "dev": "node scripts/build-episode-shards.mjs && node scripts/build-search-index.mjs && astro dev --host 0.0.0.0",
    "preview": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "astro": "astro",
    "data": "node scripts/build-data.mjs",
    "data:episodes": "node scripts/build-episode-shards.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.4",
    "astro": "^5.1.1",
    "fuse.js": "^7.0.0",
    "js-yaml": "^4.2.0",
    "openai": "^6.42.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "csv-parse": "^5.6.0",
    "serve": "^14.2.6",
    "typescript": "^5.7.2"
  }
}
