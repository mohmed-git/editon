---
import type { Title } from '../lib/types';

interface Props {
  title: Title;
}

const { title } = Astro.props;
const items = title.relatedAnimeSeasons ?? [];
const visible = title.category === 'anime' && items.length > 1;
---

{visible && (
  <section class="glass-panel p-5 md:p-6">
    <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
      <span class="flex h-6 w-1 rounded-full bg-gradient-to-b from-brand-400 to-gold-400"></span>
      المواسم المرتبطة
    </h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {items.map((item) => {
        const active = item.slug === title.slug;
        return (
          <a
            href={item.url}
            class={`group flex items-center gap-3 rounded-2xl border p-3 transition-all ${
              active
                ? 'border-brand-400/50 bg-brand-500/15 text-white'
                : 'border-white/[0.06] bg-white/[0.03] text-gray-300 hover:border-brand-400/40 hover:bg-brand-500/10 hover:text-white'
            }`}
            aria-current={active ? 'page' : undefined}
          >
            <div class="h-16 w-12 shrink-0 overflow-hidden rounded-xl bg-surface-3">
              {item.poster ? (
                <img src={item.poster} alt="" loading="lazy" decoding="async" referrerpolicy="no-referrer" class="h-full w-full object-cover" />
              ) : (
                <div class="h-full w-full bg-gradient-to-br from-brand-600/25 to-gold-500/15"></div>
              )}
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-xs font-semibold text-brand-200">{item.seasonLabel}</div>
              <div class="mt-1 line-clamp-1 text-sm font-bold">{item.title}</div>
              <div class="mt-1 text-xs text-gray-500">{item.episodesCount} حلقة</div>
            </div>
            {active && <span class="rounded-full bg-brand-400/20 px-2 py-1 text-[11px] font-bold text-brand-100">الحالي</span>}
          </a>
        );
      })}
    </div>
  </section>
)}
