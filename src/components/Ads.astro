<!-- ═══════════════════════════════════════════════
     3) Smartlink كـ Popunder ثانوي على أول نقرة
     ═══════════════════════════════════════════════ -->
<script is:inline>
(function () {
  const SMARTLINK = "https://www.effectivecpmnetwork.com/wbnrckax?key=af6decf62eddc36667ffab047fdae426";
  const KEY = "_sl_fired";
  // تشغيل مرة واحدة كل 24 ساعة
  function shouldFire() {
    const last = parseInt(sessionStorage.getItem(KEY) || "0", 10);
    return Date.now() - last > 86400000;
  }
  function fire(e) {
    // تجاهل النقرات على روابط الإعلانات نفسها
    if (e.target.closest('a[href*="effectivecpmnetwork"]')) return;
    if (!shouldFire()) return;
    sessionStorage.setItem(KEY, String(Date.now()));
    try {
      const w = window.open(SMARTLINK, "_blank", "noopener");
      if (!w) window.location.href = SMARTLINK; // fallback إذا حُجب الـ popup
    } catch (_) {}
  }
  document.addEventListener("click", fire, { once: false, passive: true });
})();
</script>
