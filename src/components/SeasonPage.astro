---
import Base from '../layouts/Base.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import EpisodicSeasonsList from './EpisodicSeasonsList.astro';
import Grid from './Grid.astro';
import RelatedAnimeSeasons from './RelatedAnimeSeasons.astro';
import SectionHeader from './SectionHeader.astro';
import type { Title, TitleIndexEntry } from '../lib/types';
import type { EpisodicKind } from '../lib/episodeRoutes';
import {
  findEpisode,
  getEpisodeRouteForTitle,
  getSeasonRouteForTitle,
  getTitleRoute,
} from '../lib/episodeRoutes';
import { SITE } from '../lib/site';
import { listingRoute } from '../lib/routes';
import { buildMainDescription, cleanBrand, getRating, getWorkTitle, splitGenres } from '../lib/detailContent';

interface Props {
  title: Title;
  kind: EpisodicKind;
  seasonNumber: number;
  similar: TitleIndexEntry[];
}

const { title, kind, seasonNumber, similar } = Astro.props;
const workTitle = getWorkTitle(title);
const typeLabel = kind === 'series' ? 'مسلسل' : 'أنمي';
const sectionTheme = kind === 'series' ? 'series' : 'anime';
const categoryHref = listingRoute(kind);
const categoryLabel = kind === 'series' ? 'مسلسلات' : 'أنمي';
const titleRoute = getTitleRoute(title, kind);
const { season } = findEpisode(title, seasonNumber, 1);
const currentSeason = season?.season ?? seasonNumber;
const firstEpisode = season?.episodes[0] ?? null;
const pageHeading = `${typeLabel} ${workTitle} الموسم ${currentSeason}`;
const pageTitle = `${pageHeading} مترجم اون لاين — ${SITE.name}`;
const description = `تابع ${typeLabel} ${workTitle} الموسم ${currentSeason} مترجم مع قائمة الحلقات كاملة وروابط المشاهدة بجودة عالية على ${SITE.name}.`;
const canonical = new URL(getSeasonRouteForTitle(title, kind, currentSeason), SITE.url).toString();
const story = buildMainDescription(title, kind, currentSeason);
const genres = splitGenres(title.genre);
const rating = getRating(title);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TVSeason',
  name: pageHeading,
  description,
  seasonNumber: currentSeason,
  numberOfEpisodes: season?.episodes.length ?? 0,
  partOfSeries: {
    '@type': 'TVSeries',
    name: workTitle,
    url: new URL(titleRoute, SITE.url).toString(),
  },
  image: title.poster,
  inLanguage: cleanBrand(title.language) || 'ar',
  url: canonical,
};
---

<Base
  title={pageTitle}
  description={description}
  canonical={canonical}
  image={title.poster ?? undefined}
  ogType="video.tv_show"
  jsonLd={jsonLd}
  section={sectionTheme}
>
  <section class="container-app py-8 md:py-10">
    <Breadcrumbs
      items={[
        { label: 'الرئيسية', href: '/' },
        { label: categoryLabel, href: categoryHref },
        { label: workTitle, href: titleRoute },
        { label: `الموسم ${currentSeason}` },
      ]}
    />

    <div class="mt-6 glass-panel overflow-hidden">
      <div class="relative grid grid-cols-1 gap-6 p-5 md:grid-cols-[220px_1fr] md:p-7">
        <div class="absolute inset-0 -z-10">
          {title.poster && <img src={title.poster} alt="" aria-hidden="true" loading="eager" referrerpolicy="no-referrer" class="h-full w-full scale-110 object-cover opacity-25 blur-3xl" />}
          <div class="absolute inset-0 bg-gradient-to-l from-surface-0 via-surface-0/95 to-surface-0/80"></div>
        </div>
        <div class="mx-auto w-[190px] md:w-full">
          <div class="relative aspect-[2/3] overflow-hidden rounded-2xl bg-surface-3 ring-1 ring-white/10">
            {title.poster ? (
              <img src={title.poster} alt={workTitle} loading="eager" decoding="async" referrerpolicy="no-referrer" class="h-full w-full object-cover" />
            ) : (
              <div class="flex h-full items-center justify-center p-4 text-center text-sm text-gray-400">{workTitle}</div>
            )}
            <div class="badge-hd absolute right-3 top-3">{title.quality || 'HD'}</div>
          </div>
        </div>
        <div class="flex flex-col justify-center">
          <div class="mb-4 flex flex-wrap items-center gap-2">
            <span class="chip-brand">{typeLabel}</span>
            {rating && <span class="chip-surface">IMDb {rating}</span>}
            {title.year && <span class="chip-surface">{title.year}</span>}
            <span class="chip-surface">الموسم {currentSeason}</span>
            <span class="chip-surface">{season?.episodes.length ?? 0} حلقة</span>
            <span class="chip-surface">{title.seasons_count} موسم</span>
          </div>
          <h1 class="font-display text-3xl font-extrabold leading-[1.15] text-white md:text-4xl">{pageHeading}</h1>
          {genres.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {genres.map((genre) => <span class="rounded-full border border-white/[0.06] bg-white/[0.04] px-3 py-1 text-xs text-gray-300">{genre}</span>)}
            </div>
          )}
          <p class="mt-5 max-w-3xl text-sm leading-8 text-gray-300 md:text-base">{story}</p>
          {firstEpisode && (
            <a
              href={getEpisodeRouteForTitle(title, kind, currentSeason, firstEpisode.episode)}
              class="btn-primary mt-6 w-full justify-center px-7 py-3.5 text-base sm:w-auto"
            >
              مشاهدة أول حلقة
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="mt-7 grid grid-cols-1 gap-7 lg:grid-cols-12">
      <div class="space-y-6 lg:col-span-8">
        {kind === 'anime' && <RelatedAnimeSeasons title={title} />}

        <EpisodicSeasonsList
          title={title}
          kind={kind}
          activeSeason={currentSeason}
          showAllEpisodes={false}
        />
      </div>

      <aside class="space-y-5 lg:col-span-4">
        <div class="glass-panel overflow-hidden lg:sticky lg:top-24">
          <div class="relative aspect-[2/3] w-full bg-surface-3">
            {title.poster ? (
              <img
                src={title.poster}
                alt={workTitle}
                loading="lazy"
                decoding="async"
                referrerpolicy="no-referrer"
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full items-center justify-center p-6 text-center text-sm text-gray-400">{workTitle}</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-surface-0 via-transparent to-transparent"></div>
          </div>
          <div class="space-y-2 p-5 text-sm">
            <div class="flex justify-between gap-4 border-b border-white/[0.04] py-2">
              <span class="text-gray-400">نوع العمل</span>
              <span class="font-semibold text-white">{typeLabel}</span>
            </div>
            <div class="flex justify-between gap-4 border-b border-white/[0.04] py-2">
              <span class="text-gray-400">كل المواسم</span>
              <span class="font-semibold text-white">{title.seasons_count}</span>
            </div>
            <div class="flex justify-between gap-4 py-2">
              <span class="text-gray-400">كل الحلقات</span>
              <span class="font-semibold text-white">{title.episodes_count}</span>
            </div>
          </div>
        </div>
      </aside>
    </div>

    {similar.length > 0 && (
      <div class="mt-14 md:mt-20">
        <SectionHeader title="أعمال مشابهة" subtitle="اقتراحات قريبة من نفس التصنيف" eyebrow="RELATED" />
        <Grid items={similar} />
      </div>
    )}
  </section>
</Base>
