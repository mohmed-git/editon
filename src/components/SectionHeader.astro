---
interface Props {
  title: string;
  subtitle?: string;
  href?: string;
  hrefLabel?: string;
  eyebrow?: string;
}
const { title, subtitle, href, hrefLabel = 'عرض الكل', eyebrow } = Astro.props;
---

<div class="mb-6 md:mb-8 flex items-end justify-between gap-4">
  <div>
    {eyebrow && (
      <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] mb-2" style="color: var(--brand-400);">
        <span class="h-px w-8" style="background: linear-gradient(90deg, var(--brand-400), transparent);"></span>
        {eyebrow}
      </div>
    )}
    <h2 class="flex items-center gap-3 text-xl md:text-2xl lg:text-[28px] font-extrabold text-white font-display leading-tight">
      <span class="flex h-8 md:h-9 w-1 rounded-full" style="background: var(--gradient-primary); box-shadow: var(--glow);"></span>
      {title}
    </h2>
    {subtitle && <p class="mt-1.5 mr-4 text-xs md:text-sm text-gray-400">{subtitle}</p>}
  </div>
  {href && (
    <a href={href} class="group flex shrink-0 items-center gap-2 rounded-xl bg-white/[0.04] border border-white/[0.06] px-3.5 py-2 text-xs md:text-sm font-semibold text-gray-300 transition-all hover:text-white" style="--tw-border-opacity:1;">
      {hrefLabel}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transition-transform group-hover:-translate-x-1">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </a>
  )}
</div>
