---
import Base from '../layouts/Base.astro';
import { SITE } from '../lib/site';
import { listingRoute } from '../lib/routes';
---

<Base title="الصفحة غير موجودة" description={`الصفحة التي تبحث عنها غير موجودة على ${SITE.name}.`} noindex>
  <!-- Backdrop ambient lights -->
  <div class="fixed inset-0 -z-10 pointer-events-none">
    <div class="orb h-96 w-96 -top-10 -right-10 bg-brand-600 opacity-50"></div>
    <div class="orb h-96 w-96 bottom-0 -left-10 bg-neon-fuchsia opacity-50"></div>
    <div class="orb h-72 w-72 top-1/3 left-1/2 bg-neon-violet opacity-40"></div>
  </div>

  <section class="container-app flex flex-col items-center justify-center py-20 md:py-32 text-center">
    <div class="relative animate-scale-in">
      <p class="font-display text-[140px] md:text-[220px] font-extrabold leading-none text-white/5 select-none">404</p>
      <p class="absolute inset-0 flex items-center justify-center font-display text-6xl md:text-8xl font-extrabold gradient-text neon-glow">404</p>
    </div>
    <h1 class="mt-8 text-2xl md:text-4xl font-extrabold text-white animate-slide-up">
      هذه الصفحة <span class="gradient-text">ضائعة في الفضاء</span>
    </h1>
    <p class="mt-4 max-w-md text-sm md:text-base text-gray-400 animate-slide-up">
      قد يكون الرابط قديمًا أو مكتوبًا بشكل خاطئ. عُد إلى الرئيسية أو ابحث عمّا تريد.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-3 animate-slide-up">
      <a href="/" class="btn-primary text-base px-7 py-3.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        العودة للرئيسية
      </a>
      <a href="/search" class="btn-secondary text-base px-6 py-3.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        البحث
      </a>
    </div>

    <!-- Quick links -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 max-w-2xl w-full">
      <a href={listingRoute('movie')} class="glass-panel p-4 group hover:border-brand-500/30 hover:shadow-[0_0_24px_-8px_rgba(168,85,247,0.5)] transition-all">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-neon-fuchsia text-white shadow-[0_0_16px_-4px_rgba(168,85,247,0.6)]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
              <path d="M15.6 11.6L22 7v10l-6.4-4.5v-1zM2 5a2 2 0 012-2h12a2 2 0 012 2v14a2 2 0 01-2 2H4a2 2 0 01-2-2V5z"/>
            </svg>
          </div>
          <div class="text-right">
            <div class="text-sm font-bold text-white">الأفلام</div>
            <div class="text-xs text-gray-400">تصفح المكتبة</div>
          </div>
        </div>
      </a>
      <a href={listingRoute('series')} class="glass-panel p-4 group hover:border-brand-500/30 hover:shadow-[0_0_24px_-8px_rgba(168,85,247,0.5)] transition-all">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-neon-violet to-brand-600 text-white shadow-[0_0_16px_-4px_rgba(139,92,246,0.6)]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
              <rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/>
            </svg>
          </div>
          <div class="text-right">
            <div class="text-sm font-bold text-white">المسلسلات</div>
            <div class="text-xs text-gray-400">شاهد الأحدث</div>
          </div>
        </div>
      </a>
      <a href={listingRoute('anime')} class="glass-panel p-4 group hover:border-brand-500/30 hover:shadow-[0_0_24px_-8px_rgba(168,85,247,0.5)] transition-all">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-neon-fuchsia to-neon-violet text-white shadow-[0_0_16px_-4px_rgba(217,70,239,0.6)]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M12 2l1.5 4.5h4.5l-3.6 2.7L15.9 14 12 11.3 8.1 14l1.5-4.8L6 6.5h4.5L12 2z"/>
            </svg>
          </div>
          <div class="text-right">
            <div class="text-sm font-bold text-white">الأنمي</div>
            <div class="text-xs text-gray-400">عالم متجدد</div>
          </div>
        </div>
      </a>
    </div>
  </section>
</Base>
