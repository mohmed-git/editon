---
/**
 * Standalone EPISODE page for series (kind = 'series', route code "d").
 *
 * SSR (on-demand) — NOT prerendered. ~48k episodes would blow past the 20k-file
 * Cloudflare Pages limit if built statically; rendering them on demand + edge
 * caching gives full, indexable HTML per episode while emitting zero extra
 * files into `dist`.
 *
 * Data is loaded one title at a time via loadEpisodicTitle (lazy per-title
 * shard) and getSimilarTitlesLite (slim index) so the 86MB all.json is never
 * bundled into the Worker.
 */
export const prerender = false;

import EpisodePage from '../../../../../../components/EpisodePage.astro';
import { loadEpisodicTitle } from '../../../../../../lib/episodeData';
import { getSimilarTitlesLite } from '../../../../../../lib/similarLite';
import { hasEpisodePages, findEpisode } from '../../../../../../lib/episodeRoutes';

const { slug, season, episode } = Astro.params;

const seasonNumber = Number.parseInt(season ?? '', 10);
const episodeNumber = Number.parseInt(episode ?? '', 10);

const title = slug ? await loadEpisodicTitle(slug, Astro.url) : undefined;

// Guard: unknown slug, non-numeric params, or a title that is not an episodic series.
if (
  !title ||
  title.category !== 'series' ||
  !hasEpisodePages(title) ||
  Number.isNaN(seasonNumber) ||
  Number.isNaN(episodeNumber)
) {
  return new Response('Not found', { status: 404 });
}

// Resolve against the real data; 404 if the episode genuinely does not exist
// (avoids indexing duplicate/incorrect content for bogus URLs).
const { season: resolvedSeason, episode: resolvedEpisode } = findEpisode(
  title,
  seasonNumber,
  episodeNumber
);
if (
  !resolvedSeason ||
  !resolvedEpisode ||
  resolvedSeason.season !== seasonNumber ||
  resolvedEpisode.episode !== episodeNumber
) {
  return new Response('Not found', { status: 404 });
}

const similar = getSimilarTitlesLite(
  title.slug,
  title.category,
  title.genre,
  title.country,
  title.year,
  12
);

// Edge-cache policy: cache the rendered HTML on Cloudflare for 1h, and keep
// serving (slightly stale) HTML for up to a day while it revalidates in the
// background — near-static speed + SEO without storing 48k files.
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400'
);
---

<EpisodePage
  title={title}
  kind="series"
  seasonNumber={seasonNumber}
  episodeNumber={episodeNumber}
  similar={similar}
/>
