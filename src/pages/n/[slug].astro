---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TitleDetailContent from '../../components/TitleDetailContent.astro';
import { getTitlesByCategory, getSimilarTitles, toIndexEntry } from '../../lib/titles';
import { SITE } from '../../lib/site';
import type { Title } from '../../lib/types';
import { getFirstEpisodeWatchRoute, getRouteSlug } from '../../lib/episodeRoutes';
import { listingRoute } from '../../lib/routes';
import {
  buildJsonLdDescription,
  buildMetaDescription,
  buildSeoTitle,
  cleanBrand,
  getDisplayTitle,
  getRating,
  getRatingInfo,
  splitGenres,
} from '../../lib/detailContent';

const animePatternOverrides: Record<string, number> = {
  'ao-no-exorcist': 0,
  'blue-lock': 1,
  'boku-no-hero-academia': 2,
  'bungou-stray-dogs': 3,
  'diamond-no-ace-act-ii': 4,
  'dr-stone': 5,
  'golden-kamuy': 6,
  'jujutsu-kaisen': 7,
  'one-punch-man': 8,
  'oshi-no-ko': 9,
  'record-of-ragnarok': 5,
};

export async function getStaticPaths() {
  const animePatternOverrides: Record<string, number> = {
    'ao-no-exorcist': 0,
    'blue-lock': 1,
    'boku-no-hero-academia': 2,
    'bungou-stray-dogs': 3,
    'diamond-no-ace-act-ii': 4,
    'dr-stone': 5,
    'golden-kamuy': 6,
    'jujutsu-kaisen': 7,
    'one-punch-man': 8,
    'oshi-no-ko': 9,
    'record-of-ragnarok': 5,
  };
  const anime = getTitlesByCategory('anime');
  return anime.map((t, index) => ({
    params: { slug: getRouteSlug(t, 'anime') },
    props: { title: t, patternId: animePatternOverrides[t.slug] ?? Math.floor(index / 10) % 10 },
  }));
}

const { title, patternId } = Astro.props as { title: Title; patternId: number };
const detailKind = 'anime' as const;
const firstEp = title.seasons[0]?.episodes[0] ?? null;
const canWatch = (firstEp?.servers?.length || 0) > 0;
const firstEpisodeHref = getFirstEpisodeWatchRoute(title, detailKind);
const similar = getSimilarTitles(title, 12).map(toIndexEntry);
const genres = ['أنمي', ...splitGenres(title.genre).filter((genre) => genre !== 'أنمي')];
const displayTitle = getDisplayTitle(title);
const pageTitle = buildSeoTitle(title, detailKind);
const pageDescription = buildMetaDescription(title, detailKind);
const jsonLdDescription = buildJsonLdDescription(title, detailKind);
const rating = getRating(title);
const ratingInfo = getRatingInfo(title);
const videoUploadDate = title.year ? `${title.year}-01-01` : '2024-01-01';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TVSeries',
  name: displayTitle,
  description: jsonLdDescription,
  image: title.poster || undefined,
  inLanguage: cleanBrand(title.language) || 'ar',
  numberOfSeasons: title.seasons_count,
  numberOfEpisodes: title.episodes_count,
  url: new URL(title.url, SITE.url).toString(),
  ...(title.year ? { datePublished: title.year } : {}),
  genre: genres,
  ...(title.stars ? { actor: title.stars.split(/[\/،,]/).map((s: string) => ({ '@type': 'Person', name: cleanBrand(s) })).filter((actor) => actor.name) } : {}),
  ...(title.trailerId ? {
    trailer: {
      '@type': 'VideoObject',
      name: `تريلر ${displayTitle}`,
      description: `تريلر ${displayTitle} على ${SITE.name}`,
      thumbnailUrl: `https://img.youtube.com/vi/${title.trailerId}/hqdefault.jpg`,
      uploadDate: videoUploadDate,
      embedUrl: `https://www.youtube.com/embed/${title.trailerId}`,
    },
  } : {}),
};
---

<Base title={pageTitle} description={pageDescription} image={title.poster ?? undefined} ogType="video.tv_show" jsonLd={jsonLd} section="anime">
  <section class="relative -mt-16 overflow-hidden pt-16 lg:-mt-[72px] lg:pt-[72px]">
    <div class="absolute inset-0 -z-10">
      {title.poster && <img src={title.poster} alt="" aria-hidden="true" loading="eager" referrerpolicy="no-referrer" class="h-full w-full scale-110 object-cover opacity-40 blur-3xl" />}
      <div class="absolute inset-0 hero-overlay"></div>
      <div class="orb -top-10 right-10 h-72 w-72 bg-brand-600"></div>
      <div class="orb -left-10 top-40 h-80 w-80 bg-gold-500"></div>
    </div>

    <div class="container-app relative pb-12 pt-6 md:pb-16 md:pt-10">
      <Breadcrumbs items={[{ label: 'الرئيسية', href: '/' }, { label: 'أنمي', href: listingRoute('anime') }, { label: displayTitle }]} />

      <div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-10">
        <div class="flex justify-center md:col-span-4 md:justify-start lg:col-span-3">
          <div class="relative">
            <div class="relative aspect-[2/3] w-[240px] overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/10 sm:w-[280px] md:w-full">
              {title.poster ? <img src={title.poster} alt={displayTitle} loading="eager" referrerpolicy="no-referrer" class="h-full w-full object-cover" /> : <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-surface-3 to-surface-5 p-6 text-center text-sm text-gray-400">{displayTitle}</div>}
              <div class="badge-hd absolute right-3 top-3 shadow-[0_4px_14px_rgba(251,191,36,0.45)]">{title.quality || 'SUB'}</div>
            </div>
            <div class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-br from-brand-600/30 to-gold-500/25 blur-2xl"></div>
          </div>
        </div>

        <div class="space-y-5 md:col-span-8 lg:col-span-9">
          <div class="flex flex-wrap items-center gap-2">
            <span class="chip-brand">أنمي</span>
            {ratingInfo && (
              <span class="chip-surface inline-flex items-center gap-1" title={`التقييم من ${ratingInfo.source}`}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5 text-amber-400"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                {ratingInfo.value}
                <span class="text-[10px] text-gray-400">{ratingInfo.source}</span>
              </span>
            )}
            {title.year && <span class="chip-surface">{title.year}</span>}
            <span class="chip-surface">{title.seasons_count} موسم</span>
            <span class="chip-surface">{title.episodes_count} حلقة</span>
            {title.quality && <span class="badge-quality">{title.quality}</span>}
          </div>

          <h1 class="font-display text-3xl font-extrabold leading-[1.1] text-white md:text-4xl lg:text-5xl">{displayTitle}</h1>

          {genres.length > 0 && <div class="flex flex-wrap gap-2">{genres.map((genre) => <span class="inline-flex items-center rounded-full border border-white/[0.06] bg-white/[0.04] px-3 py-1 text-xs text-gray-300">{genre}</span>)}</div>}

          {canWatch && (
            <div class="flex flex-wrap gap-3 pt-1">
              <a href={firstEpisodeHref} class="btn-primary px-7 py-3.5 text-base">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M8 5v14l11-7z" /></svg>
                مشاهدة الحلقة الأولى
              </a>
            </div>
          )}

          <div class="grid grid-cols-2 gap-3 pt-4 sm:grid-cols-4">
            <div class="glass-panel-sm p-3"><div class="text-[10px] uppercase tracking-wider text-gray-500">المواسم</div><div class="mt-0.5 text-sm font-bold text-white">{title.seasons_count}</div></div>
            <div class="glass-panel-sm p-3"><div class="text-[10px] uppercase tracking-wider text-gray-500">الحلقات</div><div class="mt-0.5 text-sm font-bold text-white">{title.episodes_count}</div></div>
            <div class="glass-panel-sm p-3"><div class="text-[10px] uppercase tracking-wider text-gray-500">الجودة</div><div class="mt-0.5 text-sm font-bold text-white">{title.quality || 'HD'}</div></div>
            <div class="glass-panel-sm p-3"><div class="text-[10px] uppercase tracking-wider text-gray-500">اللغة</div><div class="mt-0.5 text-sm font-bold text-white">{cleanBrand(title.language) || 'مترجم'}</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <TitleDetailContent title={title} kind={detailKind} similar={similar} similarHref={listingRoute('anime')} patternId={patternId} />
</Base>
