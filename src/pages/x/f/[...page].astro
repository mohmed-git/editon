---
import Base from '../../../layouts/Base.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import PosterCard from '../../../components/PosterCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { getTitlesByCategory, toIndexEntry } from '../../../lib/titles';
import { PAGE_SIZE, PRIMARY_GENRES, buildYearBuckets, buildGenreCounts, genreSlug } from '../../../lib/filters';
import { listingRoute, listingPageRoute } from '../../../lib/routes';
import { SITE } from '../../../lib/site';

export async function getStaticPaths() {
  const items = getTitlesByCategory('movie').map(toIndexEntry);
  const totalPages = Math.max(1, Math.ceil(items.length / PAGE_SIZE));
  const paths: any[] = [{ params: { page: undefined }, props: { current: 1 } }];
  for (let p = 1; p <= totalPages; p++) {
    paths.push({ params: { page: `p/${p}` }, props: { current: p } });
  }
  return paths;
}

const { current } = Astro.props as { current: number };

const all = getTitlesByCategory('movie');
const items = all.map(toIndexEntry);
const yearBuckets = buildYearBuckets(all);
const genreCounts = buildGenreCounts(all);

const totalPages = Math.max(1, Math.ceil(items.length / PAGE_SIZE));
const start = (current - 1) * PAGE_SIZE;
const slice = items.slice(start, start + PAGE_SIZE);

// Client data: minimal payload for filtering (slug-keyed)
const clientPayload = items.map((e) => ({
  s: e.slug,
  y: e.year || '',
  g: e.genres || [],
}));

const visibleGenres = PRIMARY_GENRES.filter((g) => (genreCounts.get(g) || 0) > 0);

function pageHref(p: number): string {
  return listingPageRoute('movie', p);
}
---

<Base
  title={current > 1 ? `أفلام مترجمة اون لاين مجاناً — صفحة ${current}` : 'أفلام مترجمة اون لاين مجاناً'}
  description={`تصفح مكتبة ${SITE.name} التي تضم ${items.length} فيلمًا مترجمًا بجودة عالية، مع فلاتر التصنيف وسنة الإصدار.`}
  section="movies"
>
  <!-- Cinematic page header -->
  <section class="relative overflow-hidden border-b border-white/[0.04] -mt-16 lg:-mt-[72px] pt-16 lg:pt-[72px]">
    <div class="absolute inset-0 -z-10 bg-aurora opacity-70"></div>
    <div class="orb h-72 w-72 -top-10 right-10 bg-brand-600"></div>
    <div class="orb h-80 w-80 top-20 -left-20 bg-neon-fuchsia"></div>

    <div class="container-app relative pt-8 pb-10 md:pt-12 md:pb-14">
      <Breadcrumbs items={[{ label: 'الرئيسية', href: '/' }, { label: 'أفلام' }]} />

      <div class="mt-6 flex items-end justify-between flex-wrap gap-6">
        <div>
          <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-[0.25em] text-brand-400 mb-3">
            <span class="h-px w-10 bg-gradient-to-l from-brand-400 to-transparent"></span>
            MOVIES COLLECTION
          </div>
          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight">
            <span class="gradient-text neon-glow">مكتبة الأفلام</span>
          </h1>
          <p class="mt-3 max-w-2xl text-sm md:text-base text-gray-300/90 leading-relaxed">
            مجموعة فاخرة تضم {items.length.toLocaleString('ar-EG')} فيلمًا مترجمًا بجودة عالية،
            مرتّبة في {totalPages} صفحات لتصفّح أسهل وأسرع.
          </p>
        </div>

        <!-- Stats card -->
        <div class="glass-panel p-4 md:p-5 flex items-center gap-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-neon-fuchsia text-white shadow-[0_0_20px_-4px_rgba(168,85,247,0.6)]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
              <path d="M15.6 11.6L22 7v10l-6.4-4.5v-1zM2 5a2 2 0 012-2h12a2 2 0 012 2v14a2 2 0 01-2 2H4a2 2 0 01-2-2V5z"/>
            </svg>
          </div>
          <div>
            <div class="text-3xl font-extrabold gradient-text">{items.length.toLocaleString('ar-EG')}</div>
            <div class="text-xs text-gray-400 uppercase tracking-wider">فيلم متاح</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-app py-8 md:py-10">
    <!-- Filter bar (client-side) -->
    <div id="filter-bar" class="glass-panel-sm p-4 sm:p-5 my-2 mb-6 space-y-4" data-current-page={current}>
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-sm font-bold text-white flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand-400">
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
          </svg>
          تصفية النتائج
          <span id="result-count" class="chip-surface text-[11px] !py-0.5 !px-2 mr-1">{items.length.toLocaleString('ar-EG')}</span>
        </h2>
        <button id="clear-filters" type="button" class="hidden inline-flex items-center gap-1.5 text-xs font-semibold text-rose-300 hover:text-rose-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
          مسح الفلاتر
        </button>
      </div>

      <!-- Genres -->
      <div>
        <p class="text-[11px] font-semibold text-gray-400 mb-2 tracking-wider">التصنيف</p>
        <div class="flex flex-wrap gap-2" data-filter-group="genre">
          <button type="button" class="filter-chip filter-chip--active" data-value="">الكل</button>
          {visibleGenres.map((g) => (
            <button type="button" class="filter-chip" data-value={g}>
              {g}
              <span class="filter-chip__count">{genreCounts.get(g) || 0}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Years -->
      <div>
        <p class="text-[11px] font-semibold text-gray-400 mb-2 tracking-wider">سنة الإصدار</p>
        <div class="flex flex-wrap gap-2" data-filter-group="year">
          <button type="button" class="filter-chip filter-chip--active" data-value="">الكل</button>
          {yearBuckets.map((b) => (
            <button type="button" class="filter-chip" data-value={b.key} data-bucket={b.key.endsWith('s') ? 'decade' : 'year'}>
              {b.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Results: server-rendered slice (current page) -->
    <div id="results-server" class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 xl:grid-cols-6">
      {slice.map((entry, i) => (
        <PosterCard entry={entry} priority={i < 6} />
      ))}
    </div>

    <!-- Filtered results (hidden until a filter is applied) -->
    <div id="results-filtered" class="hidden grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 xl:grid-cols-6"></div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-20">
      <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-surface-3 to-surface-5 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-8 w-8 text-gray-500">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
      </div>
      <h3 class="text-lg font-bold text-white mb-1">لا توجد نتائج</h3>
      <p class="text-sm text-gray-400">جرّب تغيير الفلاتر أو إزالتها</p>
    </div>

    <!-- Server-side pagination (visible when no filters applied) -->
    <div id="server-pagination">
      <Pagination current={current} total={totalPages} hrefFor={pageHref} />
    </div>
  </section>

  <!-- Client-side data: full index (slim) + posters lookup -->
  <script type="application/json" id="all-items-data" set:html={JSON.stringify(items)} />
  <script type="application/json" id="filter-data" set:html={JSON.stringify(clientPayload)} />
</Base>

<script>
  /* eslint-disable */
  type Entry = {
    slug: string;
    clean_title: string;
    category: string;
    category_label: string;
    poster: string | null;
    seasons_count: number;
    episodes_count: number;
    url: string;
    has_multiple_seasons: boolean;
    year?: string | null;
    genres?: string[];
  };

  const PAGE_SIZE = 36;

  const itemsData: Entry[] = JSON.parse(document.getElementById('all-items-data')!.textContent || '[]');

  const filterBar = document.getElementById('filter-bar')!;
  const resultsServer = document.getElementById('results-server')!;
  const resultsFiltered = document.getElementById('results-filtered')!;
  const emptyState = document.getElementById('empty-state')!;
  const serverPagination = document.getElementById('server-pagination')!;
  const resultCount = document.getElementById('result-count')!;
  const clearBtn = document.getElementById('clear-filters')!;

  let activeGenre = '';
  let activeYear = '';
  let filterPage = 1;

  // Read URL params on load (so filters survive navigation)
  const url = new URL(window.location.href);
  activeGenre = url.searchParams.get('genre') || '';
  activeYear = url.searchParams.get('year') || '';
  filterPage = Number(url.searchParams.get('p') || '1') || 1;

  function qualityFor(slug: string): string {
    let h = 0;
    for (let i = 0; i < slug.length; i++) h = (h * 17 + slug.charCodeAt(i)) >>> 0;
    return h % 5 === 0 ? '4K' : 'HD';
  }

  function entryHasGenre(e: Entry, g: string): boolean {
    if (!g) return true;
    return (e.genres || []).some((x) => x === g);
  }

  function entryMatchesYear(e: Entry, key: string): boolean {
    if (!key) return true;
    if (key.endsWith('s')) {
      const d = parseInt(key, 10);
      const y = Number(e.year);
      return Number.isFinite(y) && y >= d && y < d + 10;
    }
    return String(e.year) === key;
  }

  function applyFilters(): Entry[] {
    return itemsData.filter((e) => entryHasGenre(e, activeGenre) && entryMatchesYear(e, activeYear));
  }

  function renderCard(e: Entry): string {
    const quality = qualityFor(e.slug);
    const posterHTML = e.poster
      ? `<img src="${e.poster}" alt="${e.clean_title}" loading="lazy" decoding="async" referrerpolicy="no-referrer" class="h-full w-full object-cover transition-transform duration-700 ease-out"/>`
      : `<div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-surface-3 to-surface-5 text-center text-sm text-gray-400"><div class="flex flex-col items-center gap-3 p-4"><span class="line-clamp-2 text-xs px-2">${e.clean_title}</span></div></div>`;
    const epsBlock = e.episodes_count > 1
      ? `<span class="text-gray-500">·</span><span>${e.episodes_count} حلقة</span>`
      : '';
    return `<a href="${e.url}" class="group poster-card animate-fade-in" aria-label="${e.category_label}: ${e.clean_title}">
      <div class="relative aspect-[2/3] w-full overflow-hidden rounded-2xl bg-surface-3">
        ${posterHTML}
        <div class="absolute top-0 right-0 left-0 flex items-start justify-between p-2 z-10">
          <span class="badge-category">${e.category_label}</span>
          <span class="badge-hd shadow-[0_4px_12px_-4px_rgba(168,85,247,0.6)]">${quality}</span>
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-surface-0 via-surface-0/40 to-transparent opacity-90 transition-opacity duration-500 group-hover:opacity-95"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-brand-900/70 via-brand-900/10 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
        <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-all duration-500 group-hover:opacity-100">
          <div class="flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-neon-fuchsia text-white shadow-[0_0_30px_-4px_rgba(168,85,247,0.85)] backdrop-blur-md scale-75 group-hover:scale-100 transition-transform duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7 mr-[-2px] drop-shadow-md"><path d="M8 5v14l11-7z"/></svg>
          </div>
        </div>
        <div class="absolute inset-x-0 bottom-0 p-3 sm:p-3.5 z-10">
          <h3 class="line-clamp-2 text-[13px] sm:text-sm font-bold text-white drop-shadow-lg leading-tight">${e.clean_title}</h3>
          <div class="mt-1.5 flex items-center gap-1.5 text-[10px] sm:text-[11px] text-gray-300/90"><span class="flex items-center gap-1"><span class="h-1 w-1 rounded-full bg-brand-400"></span>${e.category_label}</span>${e.year ? `<span class="text-gray-500">·</span><span>${e.year}</span>` : ''}${epsBlock}</div>
        </div>
      </div>
    </a>`;
  }

  function renderPagination(currentP: number, totalP: number): string {
    if (totalP <= 1) return '';
    const nums: (number | '…')[] = [];
    if (totalP <= 7) {
      for (let i = 1; i <= totalP; i++) nums.push(i);
    } else {
      nums.push(1);
      const left = Math.max(2, currentP - 1);
      const right = Math.min(totalP - 1, currentP + 1);
      if (left > 2) nums.push('…');
      for (let i = left; i <= right; i++) nums.push(i);
      if (right < totalP - 1) nums.push('…');
      nums.push(totalP);
    }
    const btn = (p: number, label: string, dis: boolean, extra = '') =>
      dis
        ? `<span class="page-btn opacity-40 cursor-not-allowed">${label}</span>`
        : `<button type="button" class="page-btn" data-page="${p}" ${extra}>${label}</button>`;
    const prev = btn(currentP - 1, '<span class="hidden sm:inline">السابق</span><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 rtl:rotate-180"><path d="M15 18l-6-6 6-6"/></svg>', currentP === 1);
    const next = btn(currentP + 1, '<span class="hidden sm:inline">التالي</span><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 rtl:rotate-180"><path d="M9 6l6 6-6 6"/></svg>', currentP === totalP);
    const middle = nums
      .map((n) =>
        n === '…'
          ? `<span class="page-ellipsis">…</span>`
          : n === currentP
          ? `<span class="page-current" aria-current="page">${n}</span>`
          : `<button type="button" class="page-btn" data-page="${n}">${n}</button>`
      )
      .join('');
    return `<nav class="mt-10 flex flex-wrap items-center justify-center gap-2" aria-label="ترقيم الصفحات">${prev}${middle}${next}</nav>`;
  }

  function syncURL() {
    const params = new URLSearchParams();
    if (activeGenre) params.set('genre', activeGenre);
    if (activeYear) params.set('year', activeYear);
    if (filterPage > 1) params.set('p', String(filterPage));
    const qs = params.toString();
    const newUrl = window.location.pathname + (qs ? '?' + qs : '');
    window.history.replaceState({}, '', newUrl);
  }

  function rerender() {
    const filtered = applyFilters();
    const hasFilter = !!activeGenre || !!activeYear;
    resultCount.textContent = filtered.length.toLocaleString('ar-EG');
    clearBtn.classList.toggle('hidden', !hasFilter);

    if (!hasFilter) {
      // Show server-rendered slice + server pagination
      resultsServer.classList.remove('hidden');
      resultsFiltered.classList.add('hidden');
      emptyState.classList.add('hidden');
      serverPagination.classList.remove('hidden');
      filterPage = 1;
      syncURL();
      return;
    }

    // Filter mode: client-side render
    resultsServer.classList.add('hidden');
    serverPagination.classList.add('hidden');

    if (filtered.length === 0) {
      resultsFiltered.classList.add('hidden');
      emptyState.classList.remove('hidden');
      syncURL();
      return;
    }

    emptyState.classList.add('hidden');
    resultsFiltered.classList.remove('hidden');
    resultsFiltered.classList.add('grid');

    const totalP = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
    if (filterPage > totalP) filterPage = totalP;
    const start = (filterPage - 1) * PAGE_SIZE;
    const slice = filtered.slice(start, start + PAGE_SIZE);

    resultsFiltered.innerHTML = slice.map(renderCard).join('') + renderPagination(filterPage, totalP);

    // Bind page buttons
    resultsFiltered.querySelectorAll<HTMLButtonElement>('button[data-page]').forEach((b) => {
      b.addEventListener('click', () => {
        filterPage = Number(b.dataset.page) || 1;
        rerender();
        window.scrollTo({ top: filterBar.offsetTop - 80, behavior: 'smooth' });
      });
    });

    syncURL();
  }

  function setActive(group: string, value: string) {
    if (group === 'genre') activeGenre = value;
    if (group === 'year') activeYear = value;
    filterPage = 1;
    // Update visual state
    filterBar.querySelectorAll<HTMLButtonElement>(`[data-filter-group="${group}"] button`).forEach((b) => {
      b.classList.toggle('filter-chip--active', (b.dataset.value || '') === value);
    });
    rerender();
  }

  // Wire up filter buttons
  filterBar.querySelectorAll<HTMLButtonElement>('[data-filter-group] button').forEach((b) => {
    b.addEventListener('click', () => {
      const group = b.parentElement!.dataset.filterGroup!;
      const value = b.dataset.value || '';
      setActive(group, value);
    });
  });

  // Clear filters
  clearBtn.addEventListener('click', () => {
    activeGenre = '';
    activeYear = '';
    filterPage = 1;
    filterBar.querySelectorAll<HTMLButtonElement>('[data-filter-group] button').forEach((b) => {
      b.classList.toggle('filter-chip--active', (b.dataset.value || '') === '');
    });
    rerender();
  });

  // Apply initial state from URL
  if (activeGenre) {
    const btn = filterBar.querySelector<HTMLButtonElement>(`[data-filter-group="genre"] [data-value="${CSS.escape(activeGenre)}"]`);
    if (btn) {
      filterBar.querySelectorAll<HTMLButtonElement>('[data-filter-group="genre"] button').forEach((b) => b.classList.toggle('filter-chip--active', b === btn));
    } else {
      activeGenre = '';
    }
  }
  if (activeYear) {
    const btn = filterBar.querySelector<HTMLButtonElement>(`[data-filter-group="year"] [data-value="${CSS.escape(activeYear)}"]`);
    if (btn) {
      filterBar.querySelectorAll<HTMLButtonElement>('[data-filter-group="year"] button').forEach((b) => b.classList.toggle('filter-chip--active', b === btn));
    } else {
      activeYear = '';
    }
  }
  if (activeGenre || activeYear) rerender();
</script>

