---
/**
 * SSR detail page for a NEW (CSV-ingested) work.
 *
 * Self-contained (does not reuse the route-coupled static detail components) so
 * every internal link points at the /w + /gw SSR namespace. The full work is
 * fetched from its detail shard at request time; nothing is bundled.
 */
export const prerender = false;

import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE } from '../../lib/site';
import { newGatewayRoute, newSeasonRoute, newEpisodeRoute } from '../../lib/routes';
import { loadNewWork, loadSubcat, type SubcatCard } from '../../lib/newWorks';
import { SUB_BY_KEY, subcatRoute } from '../../lib/subcategories';
import { splitGenres, uniquifyPlot, getRatingInfo } from '../../lib/detailContent';

const { slug } = Astro.params;
const title = slug ? await loadNewWork(slug, Astro.url) : undefined;
if (!title) return new Response('Not found', { status: 404 });

const sub = (title as any).subcategory as string | undefined;
const subDef = sub ? SUB_BY_KEY[sub] : undefined;
const section = title.category === 'movie' ? 'movies' : title.category === 'anime' ? 'anime' : 'series';
const isMovie = title.category === 'movie' || title.episodes_count <= 1;
const genres = splitGenres(title.genre);
const ratingInfo = getRatingInfo(title as any);
const rating = ratingInfo ? ratingInfo.value : (title.rating ? Number(title.rating).toFixed(1) : null);
const canWatch = (title.seasons?.[0]?.episodes?.[0]?.servers?.length || 0) > 0;
const watchHref = newGatewayRoute(title.slug);
const kindLabel = title.category === 'movie' ? 'فيلم' : title.category === 'anime' ? 'أنمي' : 'مسلسل';

// Similar: pull a few cards from the same sub-category index (cheap, slim).
let similar: SubcatCard[] = [];
if (sub) {
  const list = await loadSubcat(sub, Astro.url);
  similar = list.filter((e) => e.slug !== title.slug).slice(0, 12);
}

const detailKind = title.category === 'movie' ? 'movie' : title.category === 'anime' ? 'anime' : 'series';
// Uniquified plot so this page does not duplicate the older mirror site's text.
const uniquePlot = uniquifyPlot(title as any, detailKind as any);
const displayStory = uniquePlot || title.story || title.description || '';

const pageTitle = `مشاهدة ${kindLabel} ${title.clean_title} مترجم اون لاين`;
const pageDescription = (displayStory || '').slice(0, 160) ||
  `شاهد ${title.clean_title} مترجم اون لاين بجودة عالية على ${SITE.name}.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': isMovie ? 'Movie' : 'TVSeries',
  name: title.clean_title,
  description: pageDescription,
  image: title.poster || undefined,
  inLanguage: 'ar',
  url: new URL(newGatewayRoute(title.slug), SITE.url).toString().split('?')[0],
  ...(title.year ? { datePublished: String(title.year) } : {}),
  ...(genres.length ? { genre: genres } : {}),
  ...(rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: rating, bestRating: '10', ratingCount: (title as any).tmdb_votes || 1 } } : {}),
};

function quality(s: string): string {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 17 + s.charCodeAt(i)) >>> 0;
  return h % 5 === 0 ? '4K' : 'HD';
}
---

<Base title={pageTitle} description={pageDescription} image={title.poster ?? undefined} ogType={isMovie ? 'video.movie' : 'video.tv_show'} jsonLd={jsonLd} section={section as any}>
  <section class="relative -mt-16 overflow-hidden pt-16 lg:-mt-[72px] lg:pt-[72px]">
    <div class="absolute inset-0 -z-10">
      {title.poster && (
        <img src={title.poster} alt="" aria-hidden="true" loading="eager" referrerpolicy="no-referrer" class="h-full w-full scale-110 object-cover opacity-40 blur-3xl" />
      )}
      <div class="absolute inset-0 hero-overlay"></div>
      <div class="orb -top-10 right-10 h-72 w-72 bg-brand-600"></div>
      <div class="orb -left-10 top-40 h-80 w-80 bg-gold-500"></div>
    </div>

    <div class="container-app relative pb-12 pt-6 md:pb-20 md:pt-10">
      <Breadcrumbs items={[
        { label: 'الرئيسية', href: '/' },
        ...(subDef ? [{ label: subDef.label, href: subcatRoute(subDef.code) }] : []),
        { label: title.clean_title },
      ]} />

      <div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-10">
        <div class="flex justify-center md:col-span-4 md:justify-start lg:col-span-3">
          <div class="relative">
            <div class="relative aspect-[2/3] w-[240px] overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/10 sm:w-[280px] md:w-full">
              {title.poster ? (
                <img src={title.poster} alt={title.clean_title} loading="eager" referrerpolicy="no-referrer" class="h-full w-full object-cover" />
              ) : (
                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-surface-3 to-surface-5 p-6 text-center text-sm text-gray-400">{title.clean_title}</div>
              )}
              <div class="badge-hd absolute right-3 top-3 shadow-[0_4px_14px_rgba(251,191,36,0.45)]">{quality(title.slug)}</div>
            </div>
            <div class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-br from-brand-600/30 to-gold-500/25 blur-2xl"></div>
          </div>
        </div>

        <div class="space-y-5 md:col-span-8 lg:col-span-9">
          <div class="flex flex-wrap items-center gap-2">
            <span class="chip-brand">{kindLabel}</span>
            {ratingInfo && (
              <span class="chip-surface inline-flex items-center gap-1" title={`التقييم من ${ratingInfo.source}`}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5 text-amber-400"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                {ratingInfo.value}
                <span class="text-[10px] text-gray-400">{ratingInfo.source}</span>
              </span>
            )}
            {title.year && <span class="chip-surface">{title.year}</span>}
            {title.country && <span class="chip-surface">{title.country}</span>}
            {!isMovie && <span class="chip-surface">{title.episodes_count} حلقة</span>}
          </div>

          <h1 class="font-display text-3xl font-extrabold leading-[1.1] text-white md:text-4xl lg:text-5xl">{title.clean_title}</h1>

          {genres.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {genres.map((g) => <span class="inline-flex items-center rounded-full border border-white/[0.06] bg-white/[0.04] px-3 py-1 text-xs text-gray-300">{g}</span>)}
            </div>
          )}

          {canWatch && (
            <div class="flex flex-wrap gap-3 pt-1">
              <a href={watchHref} class="btn-primary px-7 py-3.5 text-base">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M8 5v14l11-7z" /></svg>
                {isMovie ? 'شاهد الآن' : 'ابدأ المشاهدة'}
              </a>
            </div>
          )}

          {displayStory && (
            <div class="pt-2">
              <h2 class="mb-2 text-lg font-bold text-white">{isMovie ? `قصة فيلم ${title.clean_title}` : `قصة ${title.clean_title}`}</h2>
              <p class="text-sm leading-relaxed text-gray-300/90">{displayStory}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* Seasons & episodes (series/anime) */}
  {!isMovie && (
    <section class="container-app py-8 md:py-10">
      <h2 class="mb-5 flex items-center gap-3 text-lg font-extrabold text-white font-display">
        <span class="flex h-7 w-1 rounded-full bg-gradient-to-b from-brand-400 to-neon-fuchsia"></span>
        المواسم والحلقات
      </h2>
      <div class="space-y-6">
        {title.seasons.map((s) => (
          <div class="glass-panel p-4">
            <h3 class="mb-3 text-sm font-bold text-brand-300">الموسم {s.season} <span class="text-gray-500">({s.episodes.length} حلقة)</span></h3>
            <ul class="grid grid-cols-3 gap-2 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8">
              {s.episodes.map((ep) => (
                <li>
                  <a href={newEpisodeRoute(title.slug, s.season, ep.episode)} class="flex items-center justify-center gap-1 rounded-lg bg-white/[0.04] border border-white/[0.06] px-2 py-2 text-sm text-gray-200 transition-all hover:bg-brand-500/15 hover:border-brand-500/40 hover:text-white">
                    <span class="font-semibold">{ep.episode}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  {/* Similar */}
  {similar.length > 0 && (
    <section class="container-app py-8 md:py-10">
      <h2 class="mb-5 flex items-center gap-3 text-lg font-extrabold text-white font-display">
        <span class="flex h-7 w-1 rounded-full bg-gradient-to-b from-brand-400 to-neon-fuchsia"></span>
        أعمال مشابهة
      </h2>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 xl:grid-cols-6">
        {similar.map((e) => (
          <a href={e.url} class="group poster-card animate-fade-in" aria-label={`${e.category_label}: ${e.clean_title}`}>
            <div class="relative aspect-[2/3] w-full overflow-hidden rounded-2xl bg-surface-3">
              {e.poster ? (
                <img src={e.poster} alt={e.clean_title} loading="lazy" decoding="async" referrerpolicy="no-referrer" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"/>
              ) : (
                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-surface-3 to-surface-5 text-center text-xs text-gray-400 px-2">{e.clean_title}</div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-surface-0 via-surface-0/40 to-transparent opacity-90"></div>
              <div class="absolute inset-x-0 bottom-0 p-3 z-10">
                <h3 class="line-clamp-2 text-[13px] font-bold text-white drop-shadow-lg leading-tight">{e.clean_title}</h3>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- نسب البيانات إلى TMDB (شرط من شروط استخدام TMDB) -->
  <p class="container-app pb-10 text-center text-[11px] leading-relaxed text-gray-500">
    المعلومات والملصقات والتقييمات مأخوذة من
    <a href="https://www.themoviedb.org/" rel="noopener nofollow" target="_blank" class="text-brand-400 hover:text-brand-300 underline">TMDB (The Movie Database)</a>.
    هذا الموقع يستخدم TMDB API لكنه غير معتمَد من TMDB.
  </p>
</Base>
