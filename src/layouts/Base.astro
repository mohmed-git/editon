---
import { SITE } from '../lib/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: 'website' | 'video.movie' | 'video.tv_show' | 'video.episode' | 'article';
  jsonLd?: unknown;
  /** هوية القسم اللونية: home | anime | movies | series */
  section?: 'home' | 'anime' | 'movies' | 'series';
  keywords?: string;
}

const {
  title,
  description = SITE.description,
  image = SITE.defaultOgImage,
  canonical,
  noindex = false,
  ogType = 'website',
  jsonLd,
  section = 'home',
  keywords,
} = Astro.props;

const hasBrandSuffix = title ? new RegExp(`${SITE.name}|${SITE.nameEn}`, 'i').test(title) : false;
const fullTitle = title
  ? hasBrandSuffix ? title : `${title} | ${SITE.name}`
  : `${SITE.name} ${SITE.nameEn} — ${SITE.tagline}`;
const url = new URL(Astro.url.pathname, SITE.url).toString();
const canonicalUrl = canonical || url;
const ogImage = image && image.startsWith('http') ? image : new URL(image, SITE.url).toString();
const ogImageAlt = `${fullTitle} - ${SITE.name}`;

const defaultKeywords =
  'افلام اون لاين, مشاهدة افلام, مسلسلات مترجمة, انمي مترجم, افلام HD, مشاهدة مباشرة, سينما بلس, افلام 2024, افلام 2025, مسلسلات اجنبية, انمي اون لاين';
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content={SITE.themeColor} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords || defaultKeywords} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />}

    <!-- Preconnect + fonts (Arabic) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&family=Tajawal:wght@400;500;700;800&display=swap"
    />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ar_AR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>

  <body class="flex min-h-screen flex-col" data-section={section}>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:right-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-brand-600 focus:px-3 focus:py-2 focus:text-white">
      تخطي إلى المحتوى الرئيسي
    </a>

    <Header section={section} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
